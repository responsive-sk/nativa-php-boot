#!/usr/bin/env python3
"""
Font Optimizer - kombinovaná SK+CZ+US sada
"""

import os
from fontTools import subset

# KOMBINOVANÁ SADA SK + CZ + US
COMBINED_CHARSET = (
    # Slovenčina
    'AÁÄBCČDĎEÉFGHIÍJKLĹĽMNŇOÓÔPQRŔSŠTŤUÚVWXYÝZŽ' +
    'aáäbcčdďeéfghiíjklĺľmnňoóôpqrŕsštťuúvwxyýzž' +
    
    # Čeština (pridáme len odlišné znaky od SK)
    'ĚěŘřŮů' +  # Čo má CZ a SK nemá
    
    # English/US
    'ABCDEFGHIJKLMNOPQRSTUVWXYZ' +
    'abcdefghijklmnopqrstuvwxyz' +
    
    # Čísla
    '0123456789' +
    
    # Základná interpunkcia (optimálna pre web)
    ' !"#$%&\'()*+,-./:;<=>?@[\\]^_`{|}~' +
    '„“”‘’‚‹›«»–—•…€™€$£¥¢©®™°±×÷≠≈∞∂∫∑∏√≤≥∈∉∧∨¬→↔' +
    '§¶†‡‰' +
    
    # Špeciálne pre web
    '←↑→↓↔↕↨⇐⇑⇒⇓⇔∀∃∅∇∈∉∋∏∑−∕∗∘∙√∝∞∠∧∨∩∪∫∮∴∵∼∽≅≈≠≡≤≥⊂⊃⊄⊆⊇⊕⊗⊥⋅'
)

def create_combined_font(input_font, output_font="font-combined.woff2"):
    """Vytvorí jeden font pre SK, CZ a US"""
    
    os.makedirs("fonts", exist_ok=True)
    
    # Získaj unikátne znaky
    unique_chars = ''.join(sorted(set(COMBINED_CHARSET)))
    print(f"🔤 Kombinovaná sada: {len(unique_chars)} znakov")
    print(f"📝 Obsahuje: SK + CZ + US + čísla + interpunkciu")
    
    # Konvertuj na unicode range
    def chars_to_range(chars):
        codes = sorted(set(ord(c) for c in chars))
        ranges = []
        start = end = codes[0]
        
        for code in codes[1:]:
            if code == end + 1:
                end = code
            else:
                ranges.append(f"U+{start:04X}" if start == end else f"U+{start:04X}-{end:04X}")
                start = end = code
        
        ranges.append(f"U+{start:04X}" if start == end else f"U+{start:04X}-{end:04X}")
        return ','.join(ranges)
    
    unicode_range = chars_to_range(unique_chars)
    print(f"📊 Unicode range: {len(unicode_range.split(','))} blokov")
    
    # Subset args
    args = [
        input_font,
        f"--output-file=fonts/{output_font}",
        f"--unicodes={unicode_range}",
        "--flavor=woff2",
        "--layout-features=*",  # Všetky OpenType features
        "--desubroutinize",
        "--no-hinting",  # Web nepotrebuje hinting
        "--obfuscate-names",  # Ochrana fontu
        "--recommended-glyphs",
        "--name-IDs=0,3,4,6",  # Zachovať dôležité name records
        "--name-legacy",
        "--retain-gids",
        "--notdef-outline",
        "--prune-unicode-ranges",
        "--canonical-order",
    ]
    
    try:
        # Spusti subset
        subset.main(args)
        
        # Štatistiky
        input_size = os.path.getsize(input_font) / 1024
        output_size = os.path.getsize(f"fonts/{output_font}") / 1024
        reduction = ((input_size - output_size) / input_size) * 100
        
        print(f"\n{'='*60}")
        print(f"✅ KOMBINOVANÝ FONT VYTVORENÝ!")
        print(f"{'='*60}")
        print(f"📁 Vstup:        {input_font}")
        print(f"📁 Výstup:       fonts/{output_font}")
        print(f"🌐 Jazyky:       SK + CZ + US")
        print(f"🔤 Znakov:       {len(unique_chars)}")
        print(f"📊 Veľkosť:      {input_size:.1f}KB → {output_size:.1f}KB")
        print(f"📉 Zmenšenie:    {reduction:.1f}%")
        print(f"{'='*60}")
        
        # Vytvor CSS
        create_css_file(output_font, len(unique_chars), output_size)
        
        # Vytvor testovací HTML
        create_test_html(unique_chars)
        
    except Exception as e:
        print(f"❌ Chyba: {e}")

def create_css_file(font_name, char_count, file_size):
    """Vytvorí CSS súbor"""
    
    css = f"""/* 
 * Kombinovaný font pre SK + CZ + US
 * {char_count} znakov, {file_size:.1f}KB
 */

@font-face {{
    font-family: 'MultiLangFont';
    src: url('{font_name}') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
    /* Optimalizácia pre moderné prehliadače */
    font-feature-settings: "kern" 1, "liga" 1, "calt" 1;
}}

/* Utility triedy */
.sk-text, .cz-text, .en-text {{
    font-family: 'MultiLangFont', -apple-system, BlinkMacSystemFont, 
                 'Segoe UI', Roboto, sans-serif;
}}

/* Optimalizácia renderingu */
body {{
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
}}

/* Testovacie triedy */
.test-box {{
    padding: 1rem;
    margin: 1rem 0;
    border-left: 4px solid;
    background: #f8f9fa;
    border-radius: 4px;
}}

.sk-test {{ border-color: #2e7d32; }}
.cz-test {{ border-color: #d32f2f; }}
.en-test {{ border-color: #1976d2; }}
"""
    
    with open("fonts/styles.css", "w", encoding="utf-8") as f:
        f.write(css)
    
    print(f"📝 CSS vytvorený: fonts/styles.css")

