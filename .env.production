# =============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env on your production server
# NEVER commit .env to git!

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.responsive.sk
APP_TIMEZONE=Europe/Bratislava

# ----------------------------------------------------------------------------
# Database (SQLite)
# ----------------------------------------------------------------------------
DB_CMS=data/cms.db
DB_JOBS=data/jobs.db

# ----------------------------------------------------------------------------
# Admin Credentials (CHANGE THESE IMMEDIATELY!)
# ----------------------------------------------------------------------------
ADMIN_EMAIL=admin@phpcms.local
ADMIN_PASSWORD=YourSecurePassword123!

# ----------------------------------------------------------------------------
# Queue System
# ----------------------------------------------------------------------------
QUEUE_CONNECTION=sqlite

# ----------------------------------------------------------------------------
# Cache Settings
# ----------------------------------------------------------------------------
CACHE_DRIVER=file
TEMPLATE_CACHE_VERSION=1

# ----------------------------------------------------------------------------
# Session Settings
# ----------------------------------------------------------------------------
SESSION_LIFETIME=120
SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# ----------------------------------------------------------------------------
# Security
# ----------------------------------------------------------------------------
# Generate a unique key for production!
# php -r "echo bin2hex(random_bytes(32));"
APP_KEY=

# ----------------------------------------------------------------------------
# Email (Optional - for contact forms)
# ----------------------------------------------------------------------------
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=noreply@example.com
# MAIL_PASSWORD=YourEmailPassword
# MAIL_FROM=noreply@responsive.sk
# MAIL_ENCRYPTION=tls

# ----------------------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------------------
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_DECAY=60

# ----------------------------------------------------------------------------
# File Uploads
# ----------------------------------------------------------------------------
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx

# ----------------------------------------------------------------------------
# Performance
# ----------------------------------------------------------------------------
OPCACHE_ENABLED=true
TEMPLATE_CACHE_ENABLED=true
